<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <meta name="language" content="es">
  <!--GOOGLE FONTS-->
  <link rel="preconnect" href="https://fonts.gstatic.com">
  <link href="https://fonts.googleapis.com/css2?family=Raleway&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap" rel="stylesheet">
  <!--letra Form Individual-->
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Khojki&display=swap" rel="stylesheet">
  <!--letra Menu izquierda-->
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap" rel="stylesheet">
  <!--GOOGLE ICONs-->
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
  <!--CUSTOM CSS-->
  <link rel="stylesheet" href="/css/style.css">

  <title>SBC</title>
</head>

<body>
  <div class="containerMain">
    <div class="navegacionSupHomeMain">
      <div class="primeraParteNavegacion">

        <img src="/img/completoBlancoSF.png" class="logoPrincipal" alt="Logo" class="img">

      </div>

      <div class="ultimaParte">
        <img src="/img/logoNew.png" class="logoPrincipal" alt="Logo" class="img">

      </div>

    </div>
  </div>
  <div class="medio">

  </div>

  <div class="cuerpoMedia">


  </div>

  </form>

  </div>

  <!--JQUERY-->
  <script src="/js/librerias/jquery-3.4.1.min.js "></script>
  <script src="/js/librerias/carteles.js"></script>
  <script src="/js/home/variablesIniciales/onElementGrales.js"></script>
  <script src="/js/librerias/sortable.js"></script>

  <script>

    const id = "<%= userId._id %>";
    const usuario = "<%= userId.usernameUser %>";

    agregarCotinaNegra(`body`);

    let cartel = cartelComplemento({}, "", { claseCartel: "widthCuarenta blanquearPassword paddingAmplio black", bloques: 2, clasebloqueCabecera: "oculto" })
    console.log(cartel)
    $(cartel).appendTo(`body`);

    let bloqueCero = `<div class="recuperar-container">`;
    $(bloqueCero).appendTo(`.bloque0`);

    let bloqueUno = `<form method="PUT" id="blanquearContrasena"></form>`;
    bloqueUno += `<div class="usuario marginBot"><h5>Usuario: ${usuario}</h5>
      <input type="hidden" value="${id}" name="_id" form="blanquearContrasena" /> </div>`
    bloqueUno += `<div class="inputs">
            <div class="contrasena inputDiv flex marginBot">
            <input type="password" class="requerido contrasena" placeholder="Contraseña" id="contrasena" name="contrasena" form="blanquearContrasena" />
            <span class="material-symbols-outlined oculto ojito">visibility</span>
            <span class="material-symbols-outlined tachado ojito">visibility_off</span>
            </div>
            <div class="paddingCero textoValidacionContrasena oculto"><p class="bold">La contraseña debe tener al menos una mayúscula, un número y un caracter especial</p></div>`;
    bloqueUno += `<div class="repetirContrasena inputDiv flex marginBot">
            <input class="requerido" type="password" placeholder="Repetir Contraseña" id="repetirContrasena" />
            <span class="material-symbols-outlined oculto ojito">visibility</span>
            <span class="material-symbols-outlined tachado ojito">visibility_off</span>
            </div>
            <div class="paddingCero textoValidacionRep oculto"><p class="bold">La contraseñas no coinciden</p></div>`;
    bloqueUno += `<button class="botonEnviar">💾 Blanquear contraseña</button></div>`;
    $(bloqueUno).appendTo(`.bloque1`);

    function validarPassword(e) {

      const password = $(this).val();
      const tieneNumero = /[0-9]/.test(password);
      const tieneEspecial = /[@$!%*?&]/.test(password);
      const tieneMayuscula = /[A-Z]/.test(password);

      if (tieneNumero && tieneEspecial && tieneMayuscula) {
        $(this).addClass("validado");
        $(`.cartelComplemento div.textoValidacionContrasena`).addClass(`oculto`);

      } else {

        $(this).removeClass("validado");
        $(`.cartelComplemento div.textoValidacionContrasena`).removeClass(`oculto`);

      }
    }
    $(`body`).on(`input`, `.cartelComplemento.blanquearPassword input.contrasena`, validarPassword);

    function contrasenaIguales(e) {

      const pass1 = $(`.cartelComplemento.blanquearPassword #contrasena`).val();
      const pass2 = $(`.cartelComplemento.blanquearPassword #repetirContrasena`).val();

      if (pass1 && pass2 && pass1 == pass2) {

        $(`.textoValidacionRep`).addClass("oculto");
        $(`.cartelComplemento.blanquearPassword #repetirContrasena`).addClass("validado");

      } else {
        $(`.textoValidacionRep`).removeClass("oculto");
        $(`.cartelComplemento.blanquearPassword #repetirContrasena`).removeClass("validado");

      }
    }
    $(`body`).on(`input`, `.cartelComplemento.blanquearPassword .inputs input`, contrasenaIguales)

    const changeOjito = (e) => {
      let parents = $(e.target).parents(`.inputDiv`);

      if ($(e.target).hasClass(`tachado`)) {
        $("input", parents).attr(`type`, `text`);
      } else {
        $("input", parents).attr(`type`, `password`);
      }

      $(`span`, parents).toggleClass("oculto");
    };

    $(`body`).on(`click`, `.cartelComplemento.blanquearPassword span.ojito`, changeOjito);

    function enviarBlanqueo() {

      const _id = $(`.cartelComplemento input[name="_id"]`).val()
      const password = $(`.cartelComplemento input[name="contrasena"]`).val()
      const contrasenaVal = $(`.cartelComplemento input[name="contrasena"]`).hasClass(`validado`)
      const repetirVal = $(`.cartelComplemento div.repetirContrasena input`).hasClass(`validado`)

      if (contrasenaVal == false || repetirVal == false) {

        let cartel = `<div class="cartelInformativo">
        <h5>Revise los campos en rojo</h5></div>`

        $(cartel).appendTo(`.cartelComplemento.blanquearPassword`);

        $(`.cartelComplemento.blanquearPassword`).one(`focus`, `input`, (e) => {

          $(`.cartelInformativo`).remove();

        })
        return;
      }
      
      fetch("/blanquearContrasena", {
        method: "PUT",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ _id, password })
      })
        .then(res => res.json())
        .then(data => {
        
          $(`.cartelComplemento.blanquearPassword`).remove();

          let cartel = cartelInforUnaLineaBotonEnviar({ mensaje: "La contraseña fue actualizada", mensajeBoton: "Loguearse" }, { iconoTexto: "✔️", iconoBoton: "🔓" },)

          $(cartel).appendTo(`body`);

        })
        .catch(err => {
          console.error("Error al enviar:", err);

        });
    }

    function redirigir(e) {

      e.preventDefault();
      window.location.href = "/";
    }
    $(`body`).on(`click`, `.cartelComplemento.blanquearPassword .botonEnviar`, enviarBlanqueo);
    $(`body`).on(`click`, `.cartelInfo .botonEnviar`, redirigir);
  </script>
</body>

</html>