<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="language" content="es">
    <!--GOOGLE FONTS-->
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Raleway&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap" rel="stylesheet">
    <!--letra Form Individual-->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Khojki&display=swap" rel="stylesheet">
    <!--letra Menu izquierda-->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap" rel="stylesheet">
    <!--GOOGLE ICONs-->
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <!--CUSTOM CSS-->
    <link rel="stylesheet" href="/css/style.css">
    

    <title>SBC</title>
</head>

<body>
    <div class="containerMain">
        <div class="navegacionSupHomeMain">
            <div class="primeraParteNavegacion">

                <div class="logoGesfin">
                    <div class="flecha">&nbsp;</div>
                    <div class="logoGesfin_icon uno">&nbsp;</div>
                    <div class="logoGesfin_icon dos">&nbsp;</div>
                    <div class="logoGesfin_icon tres">&nbsp;</div>
                    <div class="logoGesfin_icon cuatro">&nbsp;</div>

                </div>
                <div class="letrasGesfin">
                    <p>GESFIN</p>
                </div>

            </div>

            <div class="ultimaParte">
                <img src="/img/sbcsinFondo.png" class="logoPrincipal" alt="Logo" class="img">

            </div>

        </div>
    </div>
    <div class="medio">
        <% if (error.length> 0) {%>
            <div class="cartelError">
                <%= error %>
            </div>
            <%}%>
    </div>

    <div class="cuerpoMedia">
        <form action="/users/login" method="POST">

            <div class="inputMail">
                <span class="material-symbols-outlined">person</span>
                <input type="text" id="usernameUser" name="usernameUser" placeholder="Usuario" required />
            </div>
            <div class="inputMail">
                <span class="material-symbols-outlined">lock_open</span>
                <input type="password" id="password" name="password" placeholder="Contraseña" required />
            </div>

            <div class="inputMailLog">
                <input type="submit" value="Login" class="btnLog" />
            </div>
            <div class="olvidaste">
                <p><a href="">Olvidaste tu contraseña ?</a></p>
            </div>

    </div>

    </form>

    </div>
    <script>
        // Espera a que la página esté completamente cargada
        window.onload = function () {

            let cartelError = document.querySelector('.cartelError');
        
            if (cartelError) {
                // Desaparece el cartel después de 5 segundos (5000 milisegundos)
                setTimeout(function () {
                    cartelError.style.display = 'none';
                }, 5000);
            }
        }
    </script>
    <!--JQUERY-->
    <script rel="stylesheet" src="/js/librerias/jquery-3.4.1.min.js"></script>
    <script rel="stylesheet" src="/js/librerias/cartelError.js"></script>
</body>

</html>