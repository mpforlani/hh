<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="language" content="es">
    <!--GOOGLE FONTS-->
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Raleway&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap" rel="stylesheet">
    <!--letra Form Individual-->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Khojki&display=swap" rel="stylesheet">
    <!--letra Menu izquierda-->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap" rel="stylesheet">
    <!--GOOGLE ICONs-->
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <!--CUSTOM CSS-->
    <link rel="stylesheet" href="/css/style.css">


    <title>SBC</title>
</head>

<body>
    <div class="containerMain">
        <div class="navegacionSupHomeMain">
            <div class="primeraParteNavegacion">

                <img src="/img/completoBlancoSF.png" class="logoPrincipal img" alt="Logo" >

            </div>

            <div class="ultimaParte">
                <img src="/img/logoNew.png" class="logoPrincipal img" alt="Logo" >

            </div>

        </div>
    </div>
    <div class="medio">

    </div>

    <div class="cuerpoMedia">
        <form action="/users/login" method="POST" class="formLogin">
            <div class="logUsu">
                <img src="/img/iconos/loguser.png" class="logoPrincipal" alt="Logo" class="img">
            </div>


            <div class="inputMail">
                <span class="material-symbols-outlined">person</span>
                <input type="text" id="usernameUser" name="usernameUser" placeholder="Usuario" required />
            </div>

            <div class="inputMail">
                <span class="material-symbols-outlined lock">lock_open</span>
                <input type="password" id="password" name="password" placeholder="Contraseña" required />
                <span class="material-symbols-outlined oculto ojito">visibility</span>
                <span class="material-symbols-outlined tachado ojito">visibility_off</span>
            </div>

            <div class="inputMailLog">
                <input type="submit" value="Login" class="btnLog" />
            </div>

            <div class="olvidaste">
                <p><a>¿Olvidaste tu contraseña?</a></p>
            </div>
        </form>
    </div>

    </div>

    <!--JQUERY-->
    <script src="/js/librerias/jquery-3.4.1.min.js "></script>
    <script src="/js/librerias/carteles.js"></script>
    <script src="/js/home/variablesIniciales/onElementGrales.js"></script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/librerias/sortable.js"></script>

    <script>

        const params = new URLSearchParams(window.location.search);
        const error = params.get('error');
        const emoji = params.get('emoji');
        window.history.replaceState(null, "", window.location.pathname);

        if (error) {
            let cartelLog = cartelInforUnaLinea(error, emoji)

            $(cartelLog).appendTo('.cuerpoMedia');

            $(`#usernameUser`).val("")
            $(`#password`).val("")

        }

        $(`body`).on('click', '.inputMail', function (e) {

            let father = $(e.currentTarget)

            $(`input`, father).trigger('focus');
        });


        const changeOjito = (e) => {

            let parents = $(e.target).parents(`.inputMail `)

            if ($(e.target).hasClass(`tachado`)) {

                $("input", parents).attr(`type`, `text`)

            } else {

                $("input", parents).attr(`type`, `password`)
            }

            $(`span:not(.lock)`, parents).toggleClass("oculto")

        }

        $(`body`).on(`click`, `span.ojito`, changeOjito)

        document.addEventListener("DOMContentLoaded", function () {
            // Generar deviceId si no existe
            if (!localStorage.getItem("deviceId")) {
                localStorage.setItem("deviceId", crypto.randomUUID());
            }

            // Insertar hidden input en el formulario de login
            const form = document.querySelector("form[action='/users/login']");
            if (form) {
                const hidden = document.createElement("input");
                hidden.type = "hidden";
                hidden.name = "deviceId";
                hidden.value = localStorage.getItem("deviceId");
                form.appendChild(hidden);
            }
        });

    </script>

</body>

</html>